{% extends 'admin/base.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% trans_default_domain 'admin' %}

{% block table_content %}
{% endblock %}

{% block mainTitle %}
    {% if isEdit is true %}
        {{ 'category.edit.title'|trans({'%categ%': category.name}) }}
    {% else %}
        {{ 'category.new.title'|trans }}
    {% endif %}
    {% include 'admin/partials/_table_action_link.html.twig' with {
        'actionPath': path('admin_category_index'),
        'action': 'index',
        'cssClass': 'actions-link'
    } %}
{% endblock %}

{% block content %}

    {{ form_start(form) }}
        <div class="row">
            <div class="col-3">
                {{ form_row(form.name) }}
            </div>
            <div class="col-9">
                {{ form_row(form.image) }}
            </div>
        </div>
        {{ form_row(form.games) }}
        {% include 'common/_buttons_form.html.twig' %}
    {{ form_end(form) }}

{% endblock %}

