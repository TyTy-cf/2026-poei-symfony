{% extends 'admin/base.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block mainTitle %}
    {% if isEdit is true %}
        Modifier la catégorie "{{ category.name }}"
    {% else %}
        Ajouter une catégorie
    {% endif %}
{% endblock %}

{% block content %}

    {{ form_start(form) }}
        <div class="row">
            <div class="col-3">
                {{ form_row(form.name) }}
            </div>
            <div class="col-9">
                {{ form_row(form.image) }}
            </div>
        </div>
        {{ form_row(form.games) }}
        {% include 'common/_buttons_form.html.twig' %}
    {{ form_end(form) }}

{% endblock %}

