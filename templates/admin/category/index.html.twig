{% extends 'admin/base.html.twig' %}

{% trans_default_domain 'admin' %}


{% block mainTitle %}
    Les catégories
{% endblock %}

{% block content %}

    <table class="table table-hover table-striped table-dark">
        <thead>
        <tr>
            <th scope="col">{{ 'category.index.nom'|trans }}</th>
            <th scope="col">{{ 'category.index.image'|trans }}</th>
            <th scope="col">{{ 'category.index.slug'|trans }}</th>
            <th scope="col">{{ 'category.index.jeux'|trans }}</th>
            <th scope="col">{{ 'category.index.actions'|trans }}</th>
        </tr>
        </thead>
        <tbody>
            {% for category in categories %}

                <tr>
                    <td>{{ category.name }}</td>
                    <td>
                        {% if category.image is null %}
                            {{ 'category.index.no_image'|trans }}
                        {% else %}
                            {{ 'category.index.have_image'|trans }}
                        {% endif%}
                    </td>
                    <td>{{ category.slug }}</td>
                    <td>
                            {{ category.games|length }}
                    </td>
                    <td>
                        <button class="btn"><a href="{{ path('admin_category_edit', {'slug': category.slug}) }}"><i class="fa-solid fa-pen text-warning"></i></a></button>
                        <button class="btn"><a href="{{ path('admin_category__show', {'slug': category.slug}) }}"><i class="fa-solid fa-eye text-success"></i></a></button>
                        <button class="btn"><a href=""><i class="fa-regular fa-calendar-xmark text-danger"></i></a></button>
                    </td>
                </tr>

            {% endfor %}
        </tbody>
    </table>

{% endblock %}

