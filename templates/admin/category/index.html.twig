{% extends 'admin/base.html.twig' %}

{% block title %}Liste des catégories{% endblock %}
{% block mainTitle %}{% include 'admin/partials/navigation.html.twig' with {routeName: 'admin_dashboard', } %}
    Liste des catégories <a href="{{ path('admin_category_new') }}"><i class="fa-solid fa-square-plus"></i></a>{% endblock %}


{% block body %}
    <table class="table table-striped table-hover">
        <thead>
        <tr>
            <th scope="col">Nom</th>
            <th scope="col">Image</th>
            <th scope="col">Slug</th>
            <th scope="col">Jeux</th>
            <th scope="col">Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for category in categories %}
            <tr>
                <th>{{ category.name }}</th>
                <td><img src="{{ category.image }}" alt=""></td>
                <td>{{ category.slug }}</td>
                <td>{{ category.games | length }}</td>
                <td>
                    {% include 'admin/partials/actionButtonsSED.html.twig' with {type: 'category', slug: category.slug} %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
