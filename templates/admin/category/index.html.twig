{% extends 'admin/base.html.twig' %}

    {% block title %}Liste des catégories{% endblock %}
{% block mainTitle %}Liste des catégories <a href="{{ path('admin_add_category') }}"><i
        class="fa-solid fa-square-plus"></i></a>{% endblock %}


{% block body %}
    <table class="table table-striped table-hover">
        <thead>
        <tr>
            <th scope="col">Nom</th>
            <th scope="col">Image</th>
            <th scope="col">Slug</th>
            <th scope="col">Jeux</th>
            <th scope="col">Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for category in categories %}
            <tr>
                <th>{{ category.name }}</th>
                <td><img src="{{ category.image }}" alt=""></td>
                <td>{{ category.slug }}</td>
                <td>{{ category.games | length }}</td>
                <td>
                    <div class="d-flex align-items-stretch justify-content-evenly">
                        <a href="{{ path('admin_category', {slug: category.slug}) }}">
                            <i class="fa-solid fa-eye"></i></a>
                        <a href="{{ path('admin_edit_category', {slug: category.slug}) }}">
                            <i class="fa-solid fa-pen"></i></a>
                        <a href="{{ path('admin_delete_category', {slug: category.slug}) }}">
                            <i class="fa-solid fa-trash-can link-danger"></i></a>
                    </div>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
