{% extends 'admin/base.html.twig' %}

    {% block title %}{{ category.name }}{% endblock %}
    {% block mainTitle %}{% include 'admin/partials/navigation.html.twig' with {routeName: 'admin_category_index', } %}
        Catégorie {{ category.name }}{% endblock %}


{% block body %}
    <div class="col-3"><img src="{{ category.image }}" alt=""></div>
    <h2>Slug : {{ category.slug }}</h2>
    <h2>Jeux</h2>
    <table class="table table-striped table-hover">
        <thead>
        <tr>
            <th>Nom</th>
            <th>Image</th>
            <th>Slug</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for game in category.games %}
            <tr>
                <td>{{ game.name }}</td>
                <td>
                    <div class="ratio ratio-16x9"><img class="img-fluid" src="{{ game.thumbnailCover }}" alt=""></div>
                </td>
                <td>{{ game.slug }}</td>
                <td><div class="d-flex align-items-stretch justify-content-evenly">
                        <a href="{{ path('app_game', {slug: game.slug}) }}">
                            <i class="fa-solid fa-eye"></i></a>
{#                        <a href="{{ path('admin_edit_category', {slug: game.slug}) }}">#}
{#                            <i class="fa-solid fa-pen"></i></a>#}
                        <a href="{{ path('admin_remove_game_category', {slugGame: game.slug, slugCategory: category.slug}) }}">
                            <i class="fa-solid fa-remove link-danger"></i></a>
                    </div></td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
