{% extends 'admin/base.html.twig' %}

{% trans_default_domain 'admin' %}

{% block title %} Game Index {% endblock %}

{% block content %}
    <h1>Game index</h1>

    <table class="table table-dark table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Price</th>
                <th>Description</th>
                <th>PublishedAt</th>
                <th>ThumbnailCover</th>
                <th>Slug</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for game in games %}
            <tr>
                <td>{{ game.id }}</td>
                <td>{{ game.name }}</td>
                <td>{{ game.price }}</td>
                <td>{{ game.description }}</td>
                <td>{{ game.publishedAt ? game.publishedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ game.thumbnailCover }}</td>
                <td>{{ game.slug }}</td>
                <td>
                    <a href="{{ path('app_admin_game_show', {'id': game.id}) }}">show</a>
                    <a href="{{ path('app_admin_game_edit', {'id': game.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_admin_game_new') }}">Create new</a>
{% endblock %}
