<form method="post" action="{{ path('admin_game_delete', {'id': game.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
	<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ game.id) }}">
	<icon class="btn">
		<i class="fas fa-trash-alt text-danger"></i>
	</icon>

</form>
