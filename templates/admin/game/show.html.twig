{% extends 'admin/base.html.twig' %}

{% trans_default_domain 'admin' %}

{% block title %} Game {% endblock %}

{% block content %}
    <h1>Game</h1>

    <table class="table table-dark table-hover">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ game.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ game.name }}</td>
            </tr>
            <tr>
                <th>Price</th>
                <td>{{ game.price }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ game.description }}</td>
            </tr>
            <tr>
                <th>PublishedAt</th>
                <td>{{ game.publishedAt ? game.publishedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>ThumbnailCover</th>
                <td>{{ game.thumbnailCover }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ game.slug }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_admin_game_index') }}">back to list</a>

    <a href="{{ path('app_admin_game_edit', {'id': game.id}) }}">edit</a>

    {{ include('admin/game/_delete_form.html.twig') }}
{% endblock %}
