{% extends './admin/base.html.twig' %}


{% block body %}
	<h1>Game</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ game.id }}</td>
			</tr>
			<tr>
				<th>Name</th>
				<td>{{ game.name }}</td>
			</tr>
			<tr>
				<th>Price</th>
				<td>{{ game.price }}</td>
			</tr>
			<tr>
				<th>Description</th>
				<td>{{ game.description }}</td>
			</tr>
			<tr>
				<th>PublishedAt</th>
				<td>{{ game.publishedAt ? game.publishedAt|date('Y-m-d H:i:s') : '' }}</td>
			</tr>
			<tr>
				<th>ThumbnailCover</th>
				<td>{{ game.thumbnailCover }}</td>
			</tr>
			<tr>
				<th>Slug</th>
				<td>{{ game.slug }}</td>
			</tr>
		</tbody>
	</table>

	<div class="d-flex justify-content-left align-items-center gap-4">

		<a href="{{ path('admin_game_index') }}">
			<i class="fa-solid fa-arrow-left-long" style="color: rgb(255, 212, 59);"></i>
		</a>


		{% include './admin/component/actionButton.html.twig' with {
                    'pathAction': path('admin_game_edit', { id: game.id }),
                    'action': 'edit',
                    } %}

		{{ include('admin/game/_delete_form.html.twig') }}
		<div>
		{% endblock %}
