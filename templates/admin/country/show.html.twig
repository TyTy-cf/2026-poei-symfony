{% extends 'admin/base.html.twig' %}

{% trans_default_domain 'admin' %}

{% block mainTitle %}
    {{ country.name}}
    {% include 'admin/partials/_table_action_link.html.twig' with {
        'actionPath': path('admin_country_index'),
        'action': 'index',
        'cssClass': 'actions-link'
    } %}
    {% include 'admin/partials/_table_action_link.html.twig' with {
        'actionPath': path('admin_country_edit', {'id': country.id}),
        'action': 'edit',
        'cssClass': 'actions-link'
    } %}
{% endblock %}

{% block content %}

    <table class="table table-hover table-striped table-dark">
        <tbody>
            <tr>
                <th>Code</th>
                <td>{{ country.code }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ country.name }}</td>
            </tr>
            <tr>
                <th>Nationality</th>
                <td>{{ country.nationality }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ country.slug }}</td>
            </tr>
            <tr>
                <th>UrlFlag</th>
                <td>{{ country.urlFlag }}</td>
            </tr>
        </tbody>
    </table>

{% endblock %}
