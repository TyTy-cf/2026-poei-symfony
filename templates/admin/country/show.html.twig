{% extends 'admin/base.html.twig' %}

    {% block title %}{{ country.name }}{% endblock %}
    {% block mainTitle %}{% include 'admin/partials/navigation.html.twig' with {routeName: 'admin_country_index', } %}
        Pays {{ country.name }}{% endblock %}


{% block body %}
    <table class="table table-striped table-hover">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ country.id }}</td>
            </tr>
            <tr>
                <th>Code</th>
                <td>{{ country.code }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ country.name }}</td>
            </tr>
            <tr>
                <th>Nationality</th>
                <td>{{ country.nationality }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ country.slug }}</td>
            </tr>
            <tr>
                <th>UrlFlag</th>
                <td>{{ country.urlFlag }}</td>
            </tr>
        </tbody>
    </table>
{% endblock %}
