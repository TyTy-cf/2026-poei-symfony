<a href="{{ pathAction }}" class="{{ class|default('') }}">
	{% if action == 'edit' %}
		<i class="fas fa-edit text-warning"></i>
	{% elseif action == 'delete' %}
		<i class="fas fa-trash-alt text-danger"></i>
	{% elseif action == 'show' %}
		<i class="fas fa-eye text-info"></i>
	{% elseif action == 'add' %}
		<i class="fas fa-plus text-success text-white"></i>
	{% endif %}
</a>
