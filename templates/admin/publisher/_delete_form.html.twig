<form method="post" action="{{ path('admin_publisher_delete', {'id': publisher.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
	<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ publisher.id) }}">
	<button style="border: none; background: none;" type="submit" class="btn">
		<i class="fas fa-trash-alt text-danger"></i>

	</button>
</form>
