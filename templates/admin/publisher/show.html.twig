{% extends './admin/base.html.twig' %}


{% block body %}
	<h1>Publisher</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ publisher.id }}</td>
			</tr>
			<tr>
				<th>CreatedAt</th>
				<td>{{ publisher.createdAt ? publisher.createdAt|date('Y-m-d') : '' }}</td>
			</tr>
			<tr>
				<th>Name</th>
				<td>{{ publisher.name }}</td>
			</tr>
			<tr>
				<th>Slug</th>
				<td>{{ publisher.slug }}</td>
			</tr>
			<tr>
				<th>Website</th>
				<td>{{ publisher.website }}</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('admin_publisher_index') }}" class="btn btn-secondary">back to list</a>


	<a href="{{ path('admin_publisher_edit', {'id': publisher.id}) }}">edit</a>

	{{ include('admin/publisher/_delete_form.html.twig') }}
{% endblock %}
