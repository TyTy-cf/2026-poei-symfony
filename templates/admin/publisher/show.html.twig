{% extends 'admin/base.html.twig' %}

{% block mainTitle %}
    {% include 'admin/partials/navigation.html.twig' with {entity: publisher, action: 'show'} %}
{% endblock %}

{% block body %}
    <table class="table table-striped table-hover">
        <tbody>
        <tr>
            <th>Id</th>
            <td>{{ publisher.id }}</td>
        </tr>
        <tr>
            <th>CreatedAt</th>
            <td>{{ publisher.createdAt ? publisher.createdAt|date('Y-m-d H:i:s') : '' }}</td>
        </tr>
        <tr>
            <th>Name</th>
            <td>{{ publisher.name }}</td>
        </tr>
        <tr>
            <th>Slug</th>
            <td>{{ publisher.slug }}</td>
        </tr>
        <tr>
            <th>Website</th>
            <td>{{ publisher.website }}</td>
        </tr>
        </tbody>
    </table>
{% endblock %}
