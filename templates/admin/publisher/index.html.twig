{% extends './admin/base.html.twig' %}

{% block body %}
	<div class="d-flex justify-content-between align-items-center m-2">


		<h1>Publisher index</h1>
		{% include './admin/component/actionButton.html.twig' with {
                    'pathAction': path('admin_publisher_new'),
                    'action': 'add',
                    'class': 'btn btn-success mb-3',
                    } %}

	</div>

	<table class="table table-hover table-striped table-dark">

		<thead>
			<tr>
				<th>Id</th>
				<th>Name</th>
				<th>CreatedAt</th>
				<th>Website</th>
				<th>Slug</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for publisher in publishers %}
				<tr>
					<td>{{ publisher.id }}</td>
					<td>{{ publisher.name }}</td>
					<td>{{ publisher.createdAt ? publisher.createdAt|date('Y-m-d') : '' }}</td>
					<td>{{ publisher.website }}</td>
					<td>{{ publisher.slug }}</td>
					<td>
						<div class="d-flex justify-content-between align-items-center">


							{% include './admin/component/actionButton.html.twig' with {
                    'pathAction': path('admin_publisher_edit', { id: publisher.id }),
                    'action': 'edit',
                    } %}
							{% include './admin/component/actionButton.html.twig' with {
                    'pathAction': path('admin_publisher_show', { id: publisher.id }),
                    'action': 'show',
                    } %}
							{{ include('admin/publisher/_delete_form.html.twig') }}
						</div>
					</td>
				</tr>
			</td>
		</tbody>
	</tr>
{% else %}
	<tr>
		<td colspan="6">no records found</td>
	</tr>
{% endfor %}</tbody></table>{% endblock %}
