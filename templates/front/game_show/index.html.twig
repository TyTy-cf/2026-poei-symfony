{% extends 'front/base.html.twig' %}

{% block title %}{{ game.name }}{% endblock %}

{% block body %}

    <div class="container py-5">
        <div class="row my-5 align-items-center">
            <div class="col-6 card-show">
                <img src="{{ game.thumbnailCover }}" class="card-img-top" alt="...">
            </div>
            <div class="col-1">

            </div>
            <div class ="col-5 card-show">
                <h5>{{ game.name }}</h5>
                <p>{{ game.publishedAt|date("d-m-Y") }}</p>
                <p>{{ game.publisher.name }}</p>
                <a href="#" class="btn btn-primary">ACHETER !!!!!!!!!!!!</a>
                {% include 'front/partials/_user_own.html.twig' %}

            </div>

        </div>
        <section> {{ game.description }} </section>
    </div>

