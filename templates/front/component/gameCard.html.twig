{% if title is defined %}
	<h2 class="text-center mb-4">{{ title }}</h2>
{% endif %}

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
	{% for game in games %}
		<div class="col">
			<a class="card h-100 border-0 shadow-sm text-decoration-none text-reset overflow-hidden size-up" href="{{ path('app_game_show', {'slug': game.slug}) }}">
				<img src="{{ game.thumbnailCover }}" class="card-img-top object-fit-cover" alt="{{ game.name }}" style="height: 220px;">
				<div class="card-body d-flex flex-column gap-3">
					<div>
						<h3 class="h5 card-title mb-1">{{ game.name }}</h3>
						{% if time is defined %}
							<p class="text-body-secondary mb-0">{{ time }}</p>
						{% endif %}
					</div>
					<div class="d-flex justify-content-between align-items-center mt-auto">
						<span class="fw-semibold text-primary">{{ game.price }}€</span>
						<span class="btn btn-sm btn-outline-primary">View game</span>
					</div>
				</div>
			</a>
		</div>
	{% endfor %}
</div>
