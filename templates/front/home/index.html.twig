{% extends 'front/base.html.twig' %}

{% block title %}
    Toute l'actu G4ming !
{% endblock %}

{% block stylesheets %}
    {# parent() call back the parent code, like in a class #}
    {{ parent() }}
    {# import a specific CSS for this page, if necessary ! #}
{% endblock %}

{% block body %}

    <div class="container">
        <h1 class="text-center m-4">SteamIsh : l'actu G4ming !</h1>
    </div>


    <div class="container align-content-center">

       <div>
           <h2 class="mb-3">Les tendances</h2>
       </div>


           <div class="row justify-content-center">

               {% for gameBy in gamesBy %}

               <div class="card m-2" style="width: 18rem;">

                   <div class="card-body d-flex flex-column justify-content-between">

                       <div>
                           <img src="{{ gameBy.thumbnailCover }}" class="card-img-top" alt="game image">
                           <h5 class="card-title">{{ gameBy.name }}</h5>
                           <p class="card-text">{{ gameBy.price }}</p>
                           <a href="{{ path('app_game', {'slug': game.slug}) }}" class="btn btn-primary">Go somewhere</a>
                       </div>

                   </div>
               </div>
              {% endfor %}
           </div>

       </div>

    <div class="container align-content-center">

    <div>
        <h2 class="mb-3">Les meilleurs sorties</h2>
    </div>


        <div class="row justify-content-center">

            {% for gameByPrice in gamesByPrice %}

                <div class="card m-2 " style="width: 18rem;">

                    <div class="card-body d-flex flex-column justify-content-between">

                        <div>
                            <img src="{{ gameByPrice.thumbnailCover }}" class="card-img-top" alt="game image">
                            <h5 class="card-title">{{ gameByPrice.name }}</h5>
                            <p class="card-text">{{ gameByPrice.price }}</p>
                            <a href="#" class="btn btn-primary">Go somewhere</a>
                        </div>

                    </div>
                </div>
            {% endfor %}
        </div>

    </div>

    <div>
        <h2 class="mb-3">Top commentaires</h2>
    </div>


        <div class="row justify-content-center">
            {% for review in reviews %}
                <div class="card m-2 " style="width: 18rem;">

                    <div class="card-body d-flex flex-column justify-content-between">

                        <div>
                            <img src="{{ review.user.profileImage }}" class="card-img-top" alt="comment image">
                            <h5 class="card-title">{{ review.game.name }}</h5>
                            <p class="card-text">{{ review.rating }}</p>
                            <p class="card-text">{{ review.content|slice(0,50) }}</p>
                            <p class="card-text">{{ review.createdAt|date('d-m-y')}}</p>


                        </div>

                    </div>
                </div>

            {% endfor %}
        </div>

    <div class="container align-content-center">

    <div>
        <h2 class="mb-3">Les tops jeux</h2>
    </div>



        <div class="row justify-content-center">

            {% for gameTop in gamesTop %}

                <div class="card m-2 " style="width: 18rem;">

                    <div class="card-body d-flex flex-column justify-content-between">

                        <div>
                            <img src="{{ gameTop.thumbnailCover }}" class="card-img-top" alt="game image">
                            <h5 class="card-title">{{ gameTop.name }}</h5>
                            <p class="card-text">{{ gameTop.price }}</p>
                            <a href="#" class="btn btn-primary">Go somewhere</a>
                        </div>

                    </div>
                </div>
            {% endfor %}
        </div>

        <div>
            <h2 class="mb-3">Catégories</h2>
        </div>

        <div class="container">

            <div class="row justify-content-center">

                {% for category in categories %}

                    <div class="card m-2 " style="width: 18rem;">

                        <div class="card-body d-flex flex-column justify-content-between">

                            <div>
                                <img src="{{ category.image }}" class="card-img-top" alt="category image">
                                <h5 class="card-title">{{ category.name }}</h5>
                            </div>
                            <a href="#" class="btn btn-primary">Go somewhere</a>
                        </div>
                    </div>
                {% endfor %}
            </div>

    </div>
    </div>

{% endblock %}
