{% extends './front/base.html.twig' %}
{% trans_default_domain 'home' %}


{% block body %}

	{% if app.flashes %}
		{% for label, messages in app.flashes %}
			{% for message in messages %}
				<div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
					<div>{{ message|raw }}</div>
				</div>
			{% endfor %}
		{% endfor %}
	{% endif %}


	<section>
		<div class="container mb-5 h-50">
			{%include './front/component/gameCard.html.twig' with  {

        "games": latestReleasedGames,
        "title": 'title.latest'|trans

        } %}

		</div>
	</section>


	<section class="bg-darkdark text-light py-5">

		<div class="container mb-5">
			{%include './front/component/gameCard.html.twig' with  {
        "games": bestRatedGames,
        "title": 'title.bests'|trans

        } %}
		</div>
	</section>


	<section class="reviews mt-3 d-flex justify-content-between align-items-center flex-column">
		<h2 class="text-center mb-4">They trust us</h2>
		<div class="d-flex justify-content-between align-items-center flex-row flex-wrap ">

			{% 	for latestReview in latestReviews %}
				{%include './front/component/reviewCard.html.twig' with  {
        "latestReview": latestReview
        } %}
			{% endfor %}
		</div>

	</section>

	<section class="bg-darkdark text-light py-5">
		<div class="container">


			{%include './front/component/gameCard.html.twig' with  {
        "games": mostPlayedGames,
        "title": 'title.tops'|trans
        } %}
		</div>

	</section>
	<section>
		<div class="container">
			<div class="row g-4">


				<h2 class="text-center mb-4">Categories :</h2>


				{% 	for category in categories %}

					{% set categoryNumber = category.image|split('category-icon')|last|split('.')|first %}

					{% set categoryUrl = "https://www.instant-gaming.com/themes/igv2/modules/categoryMenu/images/category-background" ~ categoryNumber ~ ".jpg" %}


					{%include './front/component/categoryCard.html.twig' with  {
            "category": category,
            "categoryUrl": categoryUrl
            } %}
				{% endfor %}

			</div>
		</div>

	</section>


{% endblock %}
