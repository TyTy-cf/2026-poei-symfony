<footer>
    <hr class="text-danger">
    <div class="d-flex justify-content-evenly mt-4">
        <div>
            <p>{{ 'footer.title.best_categories'|trans }}</p>
            <ul class="list-unstyled">
                {% for category in best_categories() %}
                    <li><a class="text-decoration-none text-danger" href="{{ path('app_category_show', {'slug': category.slug}) }}">{{ category.name }}</a></li>
                {% endfor %}
            </ul>
        </div>

        <div>
            <p>{{ 'footer.title.commented_game'|trans }}</p>
            <ul class="list-unstyled">
                {% for game in commented_games() %}
                    <li><a class="text-decoration-none text-danger" href="{{ path('app_game_show', {'slug': game.slug}) }}">{{ game.name }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>

</footer>
