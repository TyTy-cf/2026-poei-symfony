<nav class="navbar steamish-navbar navbar-dark z-3 border-bottom border-2 border-dark position-relative top">
    <div class="container-fluid">
        <a class="navbar-brand" href="{{ path("app_home") }}">
            <i class="fa-brands fa-steam fa-3x steamish-link"></i>
        </a>
        <form class="d-flex" method="post" action="{{ path('app_game_search') }}">
            <input class="form-control me-2" name="query" type="search" placeholder="{{ 'game.search.placeholder'|trans }}"/>
            <button class="btn btn-outline-success" type="submit">{{ 'game.search.button'|trans }}</button>
        </form>

        <div class="ms-auto">
            {% if app.user is null %}
                <a class="navbar-brand steamish-link" href="{{ path("app_login") }}">Login</a>
                <a class="navbar-brand steamish-link" href="{{ path("app_register") }}">Inscription</a>
            {% else %}
                <a class="navbar-brand steamish-link" href="{{ path("app_user_show", {'name': app.user.name}) }}">Mon profil</a>
                {% if is_granted("ROLE_ADMIN") %}
                    <a class="navbar-brand steamish-link" href="{{ path("admin_home") }}">Admin</a>
                {% endif %}
                <a class="navbar-brand steamish-link" href="{{ path("app_logout") }}">Se déconnecter</a>
            {% endif %}
        </div>
    </div>
</nav>
