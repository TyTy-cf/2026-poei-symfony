<div class="card border-0 shadow-lg bg-dark bg-opacity-75 text-white h-100">
	<div class="card-body d-flex flex-column gap-3 p-4 p-lg-5">
		<div>
			<p class="text-uppercase text-white-50 small mb-2">Game page</p>
			<h1 class="display-6 fw-bold mb-2">{{ game.name }}</h1>
			<p class="text-white-50 mb-0">{{ game.publisher.name|default('No Publisher') }}</p>
		</div>

		<div class="d-flex align-items-center gap-3">
			<div class="fs-2 fw-bold text-warning">{{ game.price }}€</div>
			<span class="badge text-bg-success px-3 py-2">Available</span>
		</div>

		<div class="d-flex flex-wrap gap-2">
			{% for category in game.categories %}
				<span class="badge rounded-pill text-bg-light text-dark">{{ category.name }}</span>
			{% endfor %}
		</div>

		<div class="mt-auto pt-2 d-grid gap-2">
			<a href="{{ path('app_publisher_show', {'slug': game.publisher.slug|default('publisher') }) }}" class="btn btn-outline-light">Voir l'éditeur</a>
			<button class="btn btn-warning fw-semibold" type="button">Acheter maintenant</button>
		</div>
	</div>
</div>
