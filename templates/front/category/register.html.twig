{% extends './front/base.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block title %}
	add category
{% endblock %}

{% block body %}
	<h1 class="text-center my-5">Add a category</h1>
	<div class="row justify-content-center">
		<div class="col-6">
			{{ form_start(form) }}
			{{ form_row(form.name) }}
			{{ form_row(form.image) }}
			<div class="text-center">
				<button type="submit" class="btn btn-primary">Add</button>
			</div>
			{{ form_end(form) }}
		</div>
	</div>
{% endblock %}
