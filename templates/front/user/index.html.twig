{% extends 'front/base.html.twig' %}

{% block title %}{{ user.name }}{% endblock %}

{% block body %}
    <div class="jumbotron jumbotron-fluid bg-dark-subtle">
        <div class="container">
            <div class="row p-5">
                <div class="d-flex flex-row align-items-center">
                    <div class="col-2">
                        <img src="{{ user.profileImage | default('https://picsum.photos/200') }}" alt=""
                             class="img-thumbnail rounded-circle">
                    </div>
                    <div class="col-10 ms-3">
                        <h1 class="display-1">{{ user.name }} {% if isMe %}<a href="" class="btn btn-warning"><i class="fa-solid fa-pen"></i></a></h1>{% endif %}

                        {% if user.country %}
                            <p class="lead text-secondary"><img src="{{ user.country.urlFlag }}" alt="" class="img-fluid"> - {{ user.nickname }} - {{ user.email }}
                                - {{ user.createdAt | date("d/m/Y") }}</p>

                        {% endif %}

                        <p class="text-secondary">
                        {{ totalGameTime | game_time }}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="row m-4">
            {% include 'front/partials/gameCardsSection.html.twig' with {'games': games, "userPage": true} %}
        </div>


        <div class="row mt-5">
            <h2>Avis du joueur ({{ user.reviews.count }}) :</h2>
            <div class="row gap-3 mt-4">
                {% for review in reviews %}
                    {% include 'front/partials/reviewCard.html.twig' with {'review': review, 'cardSize': 12, 'game': review.game} %}
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}
