{% extends './front/base.html.twig' %}


{% block body %}

	<div class="primary-banner">
		<h1>{{ user.name }}</h1>
		<img src="{{ user.country.urlFlag }}" alt="Avatar" class="img-fluid rounded-circle country-flag">

	</div>
	<div class="container"></div>
	<section class="user-games">
		<h2 class="text-center mb-4">Games</h2>
		{% if user.userOwnGames is empty %}
			<div class="container py-3">
				<div class="alert alert-light border text-center mb-0" role="alert">
					This user has no games yet.
				</div>
			</div>
		{% else %}
			<div class="container py-3">

				{% include './front/component/gameCard.html.twig' with {
					games: user.userOwnGames|map(userOwnGame => userOwnGame.game)
				} only %}

			</div>
		{% endif %}
	</section>
	<section class="container py-4">
		<h2 class="text-center mb-4">Reviews</h2>
		{% if user.reviews is empty %}
			<div class="alert alert-light border text-center mb-0" role="alert">
				This user has no reviews yet.
			</div>
		{% else %}
			<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
				{% for review in user.reviews %}
					<div class="col">
						<div class="card h-100 border-0 shadow-sm rounded-4">
							<div class="card-body p-4 d-flex flex-column">
								<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
									<a href="{{ path('app_game_show', {'slug': review.game.slug}) }}">
										<h3 class="h5 mb-0">{{ review.game.name }}</h3>
									</a>
									<div class="flex-shrink-0">
										{% include './front/component/star.html.twig' with {"rating": review.rating} %}
									</div>
								</div>
								<p class="card-text text-body-secondary mb-0">{{ review.content }}</p>
							</div>
						</div>
					</div>
				{% endfor %}
			</div>
		{% endif %}
	</section>
{% endblock %}
