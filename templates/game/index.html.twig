{% extends 'front/base.html.twig' %}

{% block title %}{{ game.name }}{% endblock %}

{% block body %}


    <div class="card" style="width: 18rem;">
        <img src="{{ game.thumbnailCover }}" class="card-img-top" alt="...">
        <div class="card-body">
            <h5 class="card-title">{{ game.name }}</h5>
            <p class="card-text">{{ game.description|slice(50) }}</p>
            <a href="#" class="btn btn-primary">ACHETER !!!!!!!!!!!!</a>
            <p class="card-text">Only {{ game.price }}$</p>
        </div>
    </div>

{% endblock %}
