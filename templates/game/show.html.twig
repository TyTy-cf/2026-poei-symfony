<!DOCTYPE html>

{% block body %}
	<div
		class="col-4 mb-4 d-flex g-4 justify-content-center align-items-center">
		{# <a href="{{ path('app_game_show', {'id': game.id}) }}" style="text-decoration: none; color: inherit;"> #}
		<div class="card" style="width: 100%; height: 100%;">

			<img src="{{game.thumbnailCover}}" class="card-img-top img-fluid h-75" alt="{{game.name}}">


			<div class="card-body">
				<h5 class="card-title">{{game.name}}</h5>
				<p class="card-text">{{game.price}}
					€</p>

			</div>
		</div>
	</div>

{% endblock %}
