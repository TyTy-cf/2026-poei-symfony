{% extends './front/base.html.twig' %}


{% block body %}

	<div class="position-absolute z-0 top-20 start-0 back-img-show" style="--hero-image: url('{{ game[0].thumbnailCover }}');"></div>


	<div class="container d-flex flex-column gap-5 justify-content-center flex-column align-items-center h-100 w-100 mt-6">

		<div class="d-flex gap-5 w-100 h-100 flex-row border-rounded overflow-hidden">


			<div class="card w-100 h-75 border-rounded ratio ratio-16x9 overflow-hidden gamecard">
				<div class="border-rounded" style="background-image: url('{{ game[0].thumbnailCover }}'); background-size: cover; background-position: center;"></div>
			</div>


			<div class="card w-100 border-rounded gamecard" style="backdrop-filter: blur(20px); background-color: rgba(0, 0, 0, 0.5);">
				<div class="card-body d-flex flex-column justify-content-center align-items-center h-100 border-rounded">
					<h1 class="card-title text-white text-center">{{game[0].name}}</h1>

					<p class="card-text text-white text-center">{{game[0].price}}€</p>
				</div>
			</div>


		</div>


		<div class="d-flex w-100 h-100 flex-wrap " style="backdrop-filter: blur(20px); background-color: rgba(0, 0, 0, 0.5);">


			<h2 class="text-center mb-4">Categories :</h2>

			<div class="d-flex justify-content-between align-items-center flex-row flex-wrap gap-3">

				{% for category in game[0].categories %}
					{% for game in category %}
						<h3 class="text-white text-center">{{game.name}}</h3>

					{% endfor %}
				{% endfor %}
			</div>

		</div>


	</div>
{% endblock %}
