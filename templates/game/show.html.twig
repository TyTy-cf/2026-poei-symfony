{% extends './front/base.html.twig' %}


{% block body %}

	<div class="back-img-show" style="--hero-image: url('{{ game.thumbnailCover }}');">

		<div class="d-flex justify-content-center align-items-center h-100 w-100">
			<div class="card w-50 h-75 border-rounded" style="background-color: rgba(0, 0, 0, 0.5);">
				<div class="card-body d-flex flex-column justify-content-center align-items-center h-100" style="background-image: url('{{ game.thumbnailCover }}'); background-size: cover; background-position: center;"></div>
			</div>
			<div class="card w-50 h-75 border-rounded" style="backdrop-filter: blur(20px); background-color: rgba(0, 0, 0, 0.5);">
				<div class="card-body d-flex flex-column justify-content-center align-items-center h-100">
					<h1 class="card-title text-white text-center">{{game.name}}</h1>
					<p class="card-text text-white text-center">{{game.price}}€</p>
				</div>

			</div>


		</div>
	</div>


{% endblock %}
