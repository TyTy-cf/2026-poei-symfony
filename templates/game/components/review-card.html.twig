<div class="col">
	<div class="card h-100 border-0 shadow-sm">
		<div class="card-body p-4 d-flex flex-column gap-3">
			<div class="d-flex justify-content-between align-items-start gap-3">
				<div>
					<h3 class="h5 mb-1">{{ review.user.nickname|default(review.user.name) }}</h3>
					<p class="text-body-secondary small mb-0">{{ review.createdAt|date('d/m/Y') }}</p>
				</div>
				<div class="flex-shrink-0">
					{% include './component/star.html.twig' with { rating: review.rating } %}
				</div>
			</div>
			<p class="mb-0 text-body-secondary">{{ review.content }}</p>
		</div>
	</div>
</div>
