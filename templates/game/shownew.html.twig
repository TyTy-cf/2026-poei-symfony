{% extends './front/base.html.twig' %}

{% block title %}
	{{ game.name }}
	- Steam Ish
{% endblock %}


{% block body %}
	<div class="back-img-show text-white" style="--hero-image: url('{{ game.thumbnailCover }}');"></div>
	<div class="above-container">
		<div class="container">
			<div class="row g-4 align-items-center min-vh-75 py-5">
				<div class="col-12 col-lg-7">
					<div class="card border-0 shadow-lg overflow-hidden">
						<div class="ratio ratio-16x9">
							<img src="{{ game.thumbnailCover }}" class="w-100 h-100 object-fit-cover" alt="{{ game.name }}">
						</div>
					</div>
				</div>

				<div class="col-12 col-lg-5">
					<div class="card border-0 shadow-lg bg-dark bg-opacity-75 text-white">
						<div class="card-body d-flex flex-column gap-3 p-4 p-lg-5">
							<div>
								<p class="text-uppercase text-white-50 small mb-2">Game page</p>
								<h1 class="display-6 fw-bold mb-2">{{ game.name }}</h1>
								<p class="text-white-50 mb-0">{{ game.publisher.name|default('No Publisher') }}</p>
							</div>

							<div class="d-flex align-items-center gap-3">
								<div class="fs-2 fw-bold text-warning">{{ game.price }}€</div>
								<span class="badge text-bg-success px-3 py-2">Available</span>
							</div>

							<div class="d-flex flex-wrap gap-2">
								{% for category in game.categories %}
									<span class="badge rounded-pill text-bg-light text-dark">{{ category.name }}</span>
								{% endfor %}
							</div>

							<div class="mt-auto pt-2 d-grid gap-2">
								<a href="{{ path('app_publisher_show', {'slug': game.publisher.slug|default('publisher') }) }}" class="btn btn-outline-light">Voir l'éditeur</a>
								<button class="btn btn-warning fw-semibold" type="button">Acheter maintenant</button>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>


		<div class="container py-5">
			<div class="row g-4">
				<div class="col-12">
					<div class="card border-0 shadow-sm">
						<div class="card-body p-4 p-lg-5">
							<h2 class="h3 mb-3">Description</h2>
							{% if game.description %}
								<p class="lead text-body-secondary mb-0">{{ game.description }}</p>
							{% else %}
								<p class="text-body-secondary mb-0">Aucune description disponible pour ce jeu.</p>
							{% endif %}
						</div>
					</div>
				</div>
			</div>

			<div class="row mt-5">
				<div class="col-12">
					<div class="d-flex align-items-center justify-content-between gap-3 mb-3">
						<h2 class="h3 mb-0">Avis</h2>
						<span class="text-body-secondary">{{ game.reviews|length }}
							review(s)</span>
					</div>
					{% if game.reviews is empty %}
						<div class="alert alert-light border mb-0" role="alert">
							Aucun avis pour le moment.
						</div>
					{% else %}
						<div class="row row-cols-1 row-cols-lg-2 g-4">
							{% for review in game.reviews %}
								<div class="col">
									<div class="card h-100 border-0 shadow-sm">
										<div class="card-body p-4 d-flex flex-column gap-3">
											<div class="d-flex justify-content-between align-items-start gap-3">
												<div>
													<h3 class="h5 mb-1">{{ review.user.nickname|default(review.user.name) }}</h3>
													<p class="text-body-secondary small mb-0">{{ review.createdAt|date('d/m/Y') }}</p>
												</div>
												<div class="flex-shrink-0">
													{% include './component/star.html.twig' with { rating: review.rating } %}
												</div>
											</div>
											<p class="mb-0 text-body-secondary">{{ review.content }}</p>
										</div>
									</div>
								</div>
							{% endfor %}
						</div>
					{% endif %}
				</div>
			</div>
		</div>
	</div>

	{# Similar games can stay below if you want to extend the page later. #}
{% endblock %}

