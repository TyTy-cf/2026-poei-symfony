{% if title is defined %}
	<h2 class="text-center mb-4">{{ title }}</h2>
{% endif %}

<div class="row g-4">

	{% for game in games %}

		<div class="col-4 border-dark rounded h-100">
			<a class="card size-up h-100" href="{{ path('app_game_show', {'slug': game.slug}) }}" style="text-decoration: none; color: inherit;">
				<img src="{{game.thumbnailCover}}" class="card-img-top object-fit-cover" alt="{{game.name}}" style="height: 200px; width: 100%;">
				<div class="card-body d-flex justify-content-between">
					<h5 class="card-title font-weight-bold w-100 fs-5">{{game.name}}</h5>
					<p class="card-text text-muted  ">{{game.price}}€</p>
				</div>
        
			</a>
		</div>

	{% endfor %}

</div>
