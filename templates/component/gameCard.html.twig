<div class="row">
	{% for game in games %}

		<div class="col-4 mb-4 border-dark rounded ">
			<a class="card size-up" href="{{ path('app_game_show', {'slug': game.slug}) }}" style="text-decoration: none; color: inherit;">

				<img src="{{game.thumbnailCover}}" class="card-img-top object-fit-cover" alt="{{game.name}}" style="height: 200px; width: 100%;">
				<div class="card-body d-flex justify-content-between">
					<h5 class="card-title font-weight-bold">{{game.name}}</h5>
					<p class="card-text text-muted  ">{{game.price}}€</p>
				</div>

			</a>
		</div>
	{% endfor %}
</div>
